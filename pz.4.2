    // Кнопка 1: Заповнення масиву, виведення, сума непарних та кількість парних
    private: System::Void button1_Click(System::Object^ sender, System::EventArgs^ e) {
        try {
            n = Convert::ToInt32(textBox1->Text); // Зчитуємо розмірність з textBox1
            textBox2->Clear(); // Очищуємо поле перед виведенням нового масиву
            
            Random^ rand = gcnew Random();
            int sumOdd = 0;     // Для суми непарних
            int countEven = 0;  // Для кількості парних
            
            for (int i = 0; i < n; i++) {
                a[i] = rand->Next(0, 51); // Генеруємо випадкові числа від 0 до 50
                textBox2->AppendText(a[i].ToString() + "  "); // Виводимо через пробіл
                
                // Перевірка на непарність (залишок від ділення на 2 не дорівнює 0)
                if (a[i] % 2 != 0) {
                    sumOdd += a[i];
                } else { // Інакше - елемент парний
                    countEven++;
                }
            }
            
            // Виводимо результати обчислень у Label
            label1->Text = "Сума непарних: " + sumOdd.ToString();
            label2->Text = "Кількість парних: " + countEven.ToString();
        }
        catch (...) {
            MessageBox::Show("Введіть коректну розмірність масиву (ціле число)!", "Помилка", MessageBoxButtons::OK, MessageBoxIcon::Error);
        }
    }

